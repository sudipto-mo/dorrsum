# Copy to .env.local for local dev (never commit .env.local).
# Dev server: ./serve.sh or npm install && npm run dev (port 8080).
# Do not use `python -m http.server` at repo root — there is no root index.html; use Next.js.
# Production on Vercel: leave these unset so "Regenerate" returns Subscription only.

# Where OAuth success/error redirects land. Default: same path as NEXT_PUBLIC_CREDIT_WORKBENCH_PATH (/credit-workbench).
# Set to /coverage if you want the hub after sign-in instead of the live workbench.
# OAUTH_SUCCESS_REDIRECT=/coverage
#
# Static draft path (research gate still sends unlocked users here). Default /credit-workbench
# NEXT_PUBLIC_CREDIT_WORKBENCH_PATH=/credit-workbench

ENABLE_CONCLUSION_REGEN=true
PERPLEXITY_API_KEY=
# Optional:
# PERPLEXITY_MODEL=sonar-pro

# --- LinkedIn: full report sign-in (Sign in with LinkedIn — OpenID) ---
# Create an app at https://www.linkedin.com/developers/ — add Authorized redirect URL exactly:
#   https://YOUR_DOMAIN/api/auth/linkedin/callback
# For local Next dev (port 8080): http://localhost:8080/api/auth/linkedin/callback
#
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=https://www.principalai.pro/api/auth/linkedin/callback
# AUTH_SECRET=generate-a-long-random-string
#
# Optional: if visitors use BOTH www and apex (e.g. www.principalai.pro and principalai.pro),
# set to your registrable domain so OAuth state + session cookies work on either host:
# SESSION_COOKIE_DOMAIN=principalai.pro
#
# LinkedIn app must have product "Sign in with LinkedIn using OpenID Connect" enabled
# (Products tab). Redirect URL in LinkedIn must match LINKEDIN_REDIRECT_URI exactly
# (https, host, path — no trailing space in Vercel env values).

# --- Google: full report sign-in (OAuth 2.0, OpenID) ---
# Custom routes (not Auth.js/NextAuth): authorize → /api/auth/google/authorize, callback → /api/auth/google/callback
# "trustHost" is an Auth.js option only; it does not apply here.
#
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web application).
# Authorized redirect URIs must include the callback you use (exact scheme/host/path), e.g.:
#   https://www.principalai.pro/api/auth/google/callback
# Local Next dev (port 8080): http://localhost:8080/api/auth/google/callback
#
# Client ID / secret (aliases accepted — first non-empty wins):
#   GOOGLE_CLIENT_ID  or  AUTH_GOOGLE_ID  or  GOOGLE_ID
#   GOOGLE_CLIENT_SECRET  or  AUTH_GOOGLE_SECRET  or  GOOGLE_SECRET
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional; if unset, redirect URI is built from AUTH_URL, NEXTAUTH_URL, NEXT_PUBLIC_SITE_URL, or the incoming request URL:
# GOOGLE_REDIRECT_URI=https://www.principalai.pro/api/auth/google/callback
#
# Tip: if LinkedIn works but Google shows "not configured", Google client ID/secret are often missing in Vercel
# or use different names — set the pairs above or the AUTH_GOOGLE_* / GOOGLE_* aliases.
#
# You need at least one provider (LinkedIn or Google) plus AUTH_SECRET for sign-in to appear.

# --- Supabase: log each successful LinkedIn sign-in (optional) ---
# Create project at https://supabase.com → run SQL in supabase/migrations/001_linkedin_sign_ins.sql
# and supabase/migrations/002_google_sign_ins.sql if you use Google sign-in logging.
# Settings → API: Project URL + service_role key (server only; never expose to the browser).
#
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#    (bare project ref alone also works — same value as in the Supabase dashboard URL)
# SUPABASE_SERVICE_ROLE_KEY=
#

